package main

native fn print_i64(arg: i64): void
native fn print_str(arg: string): void

fn main(): void {
    x : i64 = 800

    if x > 500 {
        print_str("x > 500")
    } else {
        print_str("x <= 500")
    }

    print_i64(add(x, -300))
}

fn add(a: i64, b: i64): i64 {
    return a + b
}